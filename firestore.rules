rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================
    // 🔐 Studio SaaS Firestore Security Rules
    // 2026-04-19 Role-based Access Control & Public Data
    // ========================================

    function isAuth() {
      return request.auth != null;
    }

    function isDemo(studioId) {
      return studioId.matches('demo-yoga.*');
    }

    function isSuperAdmin() {
      return isAuth() && ('role' in request.auth.token) && request.auth.token.role == 'superadmin';
    }

    function isAdmin(studioId) {
      return isSuperAdmin() || (isAuth() && ('role' in request.auth.token) && request.auth.token.role == 'admin' && ('studioId' in request.auth.token) && request.auth.token.studioId == studioId);
    }

    function isInstructor(studioId) {
      return isAuth() && ('instructor' in request.auth.token) && request.auth.token.instructor == true && ('studioId' in request.auth.token) && request.auth.token.studioId == studioId;
    }

    function isMember(studioId) {
      return isAuth() && ('member' in request.auth.token) && request.auth.token.member == true && ('studioId' in request.auth.token) && request.auth.token.studioId == studioId;
    }

    function isKiosk(studioId) {
      return isAuth() && ('role' in request.auth.token) && request.auth.token.role == 'kiosk' && ('studioId' in request.auth.token) && request.auth.token.studioId == studioId;
    }

    function hasPrivateTenantAccess(studioId) {
      return isDemo(studioId) || isAdmin(studioId) || isInstructor(studioId) || isMember(studioId) || isKiosk(studioId);
    }

    // ========================================
    // 🏢 Studios - SaaS 테넌트 격리 영역
    // ========================================
    match /studios/{studioId} {
      // 🔓 PUBLIC DATA: Branding, Settings, Pricing, Schedule
      // 익명 사용자도 브랜딩 테마 및 요금표를 읽어야 랜딩페이지가 그려짐
      allow read: if isAuth(); 
      allow write: if isAdmin(studioId) || isDemo(studioId);
      
      match /settings/{docId} { allow read: if isAuth(); allow write: if isDemo(studioId) || isAdmin(studioId); }
      match /config/{docId} { allow read: if isAuth(); allow write: if isDemo(studioId) || isAdmin(studioId); }
      match /notices/{docId} { allow read: if isAuth(); allow write: if isDemo(studioId) || isAdmin(studioId); }
      match /images/{docId} { allow read: if isAuth(); allow write: if isDemo(studioId) || isAdmin(studioId); }
      match /daily_classes/{classId} { allow read: if isAuth(); allow write: if isDemo(studioId) || isAdmin(studioId) || isInstructor(studioId); }
      match /monthly_schedules/{docId} { allow read: if isAuth(); allow write: if isDemo(studioId) || isAdmin(studioId); }
      match /weekly_templates/{docId} { allow read: if isAuth(); allow write: if isDemo(studioId) || isAdmin(studioId); }

      // 🔒 PRIVATE DATA: Members, Sales, Attendance, Biometrics
      match /members/{memberId} {
        allow read: if isDemo(studioId) || isAdmin(studioId) || isInstructor(studioId) || isKiosk(studioId) || (isMember(studioId) && ('memberId' in request.auth.token) && request.auth.token.memberId == memberId);
        allow update: if isDemo(studioId) || isAdmin(studioId) || (isMember(studioId) && ('memberId' in request.auth.token) && request.auth.token.memberId == memberId);
        allow create, delete: if isDemo(studioId) || isAdmin(studioId);
      }

      match /face_biometrics/{memberId} {
        allow read, write: if isDemo(studioId) || isAdmin(studioId) || isKiosk(studioId) || (isMember(studioId) && ('memberId' in request.auth.token) && request.auth.token.memberId == memberId);
      }

      match /attendance/{attendanceId} {
        allow read: if hasPrivateTenantAccess(studioId);
        allow write: if isDemo(studioId) || isAdmin(studioId) || isInstructor(studioId) || isKiosk(studioId);
      }

      match /sales/{saleId} {
        allow read: if isDemo(studioId) || isAdmin(studioId) || (isMember(studioId) && ('memberId' in request.auth.token) && resource.data.memberId == request.auth.token.memberId);
        allow write: if isDemo(studioId) || isAdmin(studioId);
      }
      
      // 💬 Messages & Push
      match /messages/{docId} { allow read: if hasPrivateTenantAccess(studioId); allow write: if isDemo(studioId) || isAdmin(studioId); }
      match /push_history/{docId} { allow read, write: if isDemo(studioId) || isAdmin(studioId); }
      match /fcm_tokens/{docId} { allow read, write: if hasPrivateTenantAccess(studioId); }
      match /message_approvals/{docId} { allow read, write: if isDemo(studioId) || isAdmin(studioId); }
      match /bookings/{docId} { allow read: if hasPrivateTenantAccess(studioId); allow write: if isDemo(studioId) || isAdmin(studioId) || isMember(studioId); }

      // Fallback for any other studio collections (Strictly Admin only)
      match /{document=**} {
        allow read, write: if isDemo(studioId) || isAdmin(studioId);
      }
    }

    // ========================================
    // 🌍 Platform & Root Collections
    // ========================================
    match /platform/{document=**} {
      allow read, write: if isSuperAdmin();
    }
    
    match /rate_limits/{docId} {
      allow read: if isAuth();
      allow write: if false; // Cloud Functions only
    }

    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update: if isSuperAdmin();
      allow delete: if false;
    }

    match /stats/{docId} {
      allow read: if isAuth();
      allow write: if false; // Cloud Functions only
    }

    match /error_logs/{docId} {
      allow create: if isAuth();
      allow read, delete: if isSuperAdmin();
      allow update: if false;
    }

    match /ai_error_logs/{docId} { allow read: if isSuperAdmin(); allow write: if false; }
    match /ai_usage/{docId} { allow read: if isSuperAdmin(); allow write: if false; }
    match /ai_request_logs/{docId} { allow read: if isSuperAdmin(); allow write: if false; }
  }
}
