rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================
    // 🔐 복샘요가 Firestore 보안 규칙
    // 2026-02-07 세분화된 컬렉션별 규칙 적용
    // ========================================
    
    // Helper: Check if user has admin claim
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.admin == true;
    }
    
    // Helper: Check if user is instructor or higher  
    function isStaff() {
      return request.auth != null && 
             (request.auth.token.admin == true || 
              request.auth.token.instructor == true);
    }
    
    // Helper: Check if authenticated
    function isAuth() {
      return request.auth != null;
    }
    
    // ========================================
    // 📋 Members - 회원 정보
    // ========================================
    match /members/{memberId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    
    // ========================================
    // ✅ Attendance - 출석 기록
    // Any authenticated user can read, Kiosk can create, Admin can modify/delete
    // ========================================
    match /attendance/{attendanceId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }
    
    // ========================================
    // 📢 Notices - 공지사항
    // Public read, Admin write
    // ========================================
    match /notices/{noticeId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    
    // ========================================
    // 💬 Messages - 개인 메시지
    // Member reads own, Admin writes
    // ========================================
    match /messages/{messageId} {
      allow read: if isAuth() && 
                    (isAdmin() || resource.data.memberId == request.auth.uid);
      allow write: if isAdmin();
    }
    
    // ========================================
    // 🖼️ Images - 갤러리 이미지
    // Public read, Admin write
    // ========================================
    match /images/{imageId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    
    // ========================================
    // 🔔 FCM Tokens - 푸시 토큰
    // Anyone can register, Admin can read/delete
    // ========================================
    match /fcm_tokens/{tokenId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }
    
    match /fcmTokens/{tokenId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }
    
    match /push_tokens/{tokenId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }
    
    // ========================================
    // 💰 Sales - 매출 기록
    // Authenticated users can read, Admin can write
    // ========================================
    match /sales/{saleId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    
    // ========================================
    // 📅 Daily Classes - 일일 수업
    // Staff read, Admin write
    // ========================================
    match /daily_classes/{classId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    
    // ========================================
    // 🤖 AI Error Logs - AI 에러 로그
    // Admin read, Cloud Functions write only
    // ========================================
    match /ai_error_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions with Admin SDK
    }
    
    // ========================================
    // 📣 Push Campaigns - 푸시 캠페인
    // Admin only
    // ========================================
    match /push_campaigns/{campaignId} {
      allow read, write: if isAdmin();
    }
    
    // ========================================
    // ⚙️ App Config - 앱 설정
    // Public read, Admin write
    // ========================================
    match /config/{configId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    
    // ========================================
    // 📊 AI Usage Logs - AI 사용량
    // Staff read, System write
    // ========================================
    match /ai_usage/{usageId} {
      allow read: if isStaff();
      allow write: if false; // Only Cloud Functions
    }

    // ========================================
    // 🗓️ Monthly Schedules - 월간 스케줄 메타데이터
    // Staff read, Admin write
    // ========================================
    match /monthly_schedules/{scheduleId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ========================================
    // 📋 Weekly Templates - 주간 스케줄 템플릿
    // Staff read, Admin write
    // ========================================
    match /weekly_templates/{templateId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }
    // ========================================
    // ⚙️ Settings - 환경 설정 (강사 목록, 수업 종류 등)
    // Public/Auth read, Admin write
    // ========================================
    match /settings/{settingId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ========================================
    // 🧘 Member Diligence - 성실도 점수
    // Staff read, System write (via function)
    // ========================================
    match /member_diligence/{memberId} {
      allow read: if isStaff();
      allow write: if false; // Only Cloud Functions
    }

    // ========================================
    // 🐛 Client Error Logs
    // Anyone can create (for logging kiosk errors), Admin read
    // ========================================
    match /error_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuth(); // [SECURITY FIX] Require authentication (anonymous kiosk auth counts)
      allow update, delete: if isAdmin();
    }

    // ========================================
    // 📢 Push History & Approvals
    // Admin only
    // ========================================
    match /push_history/{historyId} {
      allow read, write: if isAdmin();
    }
    
    match /message_approvals/{approvalId} {
      allow read, write: if isAdmin();
    }

    // ========================================
    // 🛡️ System & Backend Collections
    // Admin read, System write (via Admin SDK)
    // ========================================
    match /rate_limits/{docId} { allow read: if isAdmin(); }
    match /meditation_ai_logs/{docId} { allow read: if isAdmin(); }
    match /practice_events/{docId} { allow read: if isAdmin(); }
    match /ai_quota/{docId} { allow read: if isAdmin(); }
    match /pending_approvals/{docId} { allow read, write: if isAdmin(); }

    // [FIX] system_state - 키오스크 동기화 트리거 등
    // 인증된 사용자(키오스크 포함)가 read, Admin만 write
    match /system_state/{docId} {
      allow read: if isAuth();
      allow write: if isAuth(); // Kiosk sync trigger needs write access
    }
    
    // [FIX] ai_request_logs - AI 요청 디버깅 로그 (Cloud Functions에서만 write)
    match /ai_request_logs/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions with Admin SDK
    }

    // ========================================
    // ⏳ Pending Attendance - 오프라인 대기 출석
    // Kiosk creates, Admin/System reads/deletes
    // ========================================
    match /pending_attendance/{id} {
      allow read: if isAuth(); // [FIX] Allow kiosk (anonymous) to read for sync count visibility
      allow create: if isAuth(); // [SECURITY FIX] Require authentication (anonymous kiosk auth counts)
      allow update, delete: if isAdmin();
    }
  }
}
