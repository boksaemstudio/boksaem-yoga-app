rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================
    // 🔐 Studio SaaS Firestore Security Rules
    // 2026-03-15 Anonymous Auth Compatible
    // ========================================
    // [NOTE] 현재 모든 Firebase Auth 사용자가 anonymous auth (custom claim 없음)
    // 따라서 isStaff()/isAdmin() 대신 isAuth()를 사용
    // 향후 admin claim 설정 후 보안 강화 예정

    // Helper: Check if authenticated
    function isAuth() {
      return request.auth != null;
    }

    // ========================================
    // 🏢 Studios - SaaS 테넌트 및 하위 컬렉션
    // ========================================
    match /studios/{studioId} {
      // 스튜디오 글로벌 문서 자체에에 대한 권한
      allow read, write: if isAuth();
      
      // 스튜디오 하위의 테넌트 격리 데이터 (members, sales, attendance 등)
      match /{document=**} {
        // [TODO] 향후 token.studioId == studioId 비교 로직으로 보안성 극대화 필요
        allow read, write: if isAuth();
      }
    }
    
    // ========================================
    // 📋 Members - 회원 정보
    // ========================================
    match /members/{memberId} {
      allow read, write: if isAuth();
    }

    // ========================================
    // 🧬 Biometrics - 안면 인식 생체 정보
    // ========================================
    match /face_biometrics/{memberId} {
      allow read, write: if isAuth();
    }
    
    // ========================================
    // ✅ Attendance - 출석 기록
    // ========================================
    match /attendance/{attendanceId} {
      allow read, write: if isAuth();
    }
    
    // ========================================
    // 📢 Notices - 공지사항
    // ========================================
    match /notices/{noticeId} {
      allow read, write: if isAuth();
    }
    
    // ========================================
    // 💬 Messages - 개인 메시지
    // ========================================
    match /messages/{messageId} {
      allow read, write: if isAuth();
    }
    
    // ========================================
    // 🖼️ Images - 갤러리 이미지
    // ========================================
    match /images/{imageId} {
      allow read, write: if isAuth();
    }
    
    // ========================================
    // 🔔 FCM Tokens - 푸시 토큰
    // ========================================
    match /fcm_tokens/{tokenId} {
      allow read, write: if isAuth();
    }
    
    match /fcmTokens/{tokenId} {
      allow read, write: if isAuth();
    }
    
    match /push_tokens/{tokenId} {
      allow read, write: if isAuth();
    }
    
    // ========================================
    // 💰 Sales - 매출 기록
    // ========================================
    match /sales/{saleId} {
      allow read, write: if isAuth();
    }
    
    // ========================================
    // 📅 Daily Classes - 일일 수업
    // ========================================
    match /daily_classes/{classId} {
      allow read, write: if isAuth();
    }
    
    // ========================================
    // 🤖 AI Error Logs
    // ========================================
    match /ai_error_logs/{logId} {
      allow read: if isAuth();
      allow write: if false; // Only Cloud Functions with Admin SDK
    }
    
    // ========================================
    // 📣 Push Campaigns - 푸시 캠페인
    // ========================================
    match /push_campaigns/{campaignId} {
      allow read, write: if isAuth();
    }
    
    // ========================================
    // ⚙️ App Config - 앱 설정
    // ========================================
    match /config/{configId} {
      allow read, write: if isAuth();
    }
    
    // ========================================
    // 📊 AI Usage Logs
    // ========================================
    match /ai_usage/{usageId} {
      allow read: if isAuth();
      allow write: if false; // Only Cloud Functions
    }

    // ========================================
    // 🗓️ Monthly Schedules - 월간 스케줄
    // ========================================
    match /monthly_schedules/{scheduleId} {
      allow read, write: if isAuth();
    }

    // ========================================
    // 📋 Weekly Templates - 주간 스케줄 템플릿
    // ========================================
    match /weekly_templates/{templateId} {
      allow read, write: if isAuth();
    }

    // ========================================
    // ⚙️ Settings - 환경 설정
    // ========================================
    match /settings/{settingId} {
      allow read, write: if isAuth();
    }

    // ========================================
    // 🧘 Member Diligence - 성실도 점수
    // ========================================
    match /member_diligence/{memberId} {
      allow read: if isAuth();
      allow write: if false; // Only Cloud Functions
    }

    // ========================================
    // 🐛 Client Error Logs
    // ========================================
    match /error_logs/{logId} {
      allow read, write: if isAuth();
    }

    // ========================================
    // 📢 Push History & Approvals
    // ========================================
    match /push_history/{historyId} {
      allow read, write: if isAuth();
    }
    
    match /message_approvals/{approvalId} {
      allow read, write: if isAuth();
    }

    // ========================================
    // 🛡️ System & Backend Collections
    // ========================================
    match /rate_limits/{docId} { allow read: if isAuth(); }
    match /meditation_ai_logs/{docId} { allow read: if isAuth(); }
    match /practice_events/{docId} { allow read: if isAuth(); }
    match /ai_quota/{docId} { allow read: if isAuth(); }
    match /pending_approvals/{docId} { allow read, write: if isAuth(); }
    match /stats/{docId} {
      allow read: if isAuth();
      allow write: if false; // Only Cloud Functions update aggregated stats
    }

    match /system_state/{docId} {
      allow read, write: if isAuth();
    }
    
    match /ai_request_logs/{docId} {
      allow read: if isAuth();
      allow write: if false; // Only Cloud Functions
    }

    // ========================================
    // ⏳ Pending Attendance - 오프라인 대기 출석
    // ========================================
    match /pending_attendance/{id} {
      allow read, write: if isAuth();
    }

    // ========================================
    // 📅 Bookings - 수업 예약
    // ========================================
    match /bookings/{bookingId} {
      allow read, write: if isAuth();
    }

    // ========================================
    // 📊 Booking Stats & Logs
    // ========================================
    match /booking_stats/{docId} {
      allow read: if isAuth();
      allow write: if false; // Only Cloud Functions
    }
    match /booking_logs/{docId} {
      allow read: if isAuth();
      allow write: if false; // Only Cloud Functions
    }
  }
}
