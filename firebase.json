{
  "hosting": [
    {
      "site": "boksaem-yoga",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "assets/**/*.png",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        },
        {
          "source": "assets/**/*.jpg",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        },
        {
          "source": "assets/**/*.webp",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        },
        {
          "source": "sw.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        }
      ]
    },
    {
      "site": "ssangmunyoga",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "sw.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        }
      ]
    },
    {
      "site": "passflowai",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
        {
          "source": "/",
          "destination": "/home.html",
          "type": 302
        }
      ],
      "rewrites": [
        {
          "source": "/sitemap.xml",
          "destination": "/sitemap.xml"
        },
        {
          "source": "/robots.txt",
          "destination": "/robots.txt"
        },
        {
          "source": "/home.html",
          "destination": "/home.html"
        },
        {
          "source": "/en/home.html",
          "destination": "/en/home.html"
        },
        {
          "source": "/ja/home.html",
          "destination": "/ja/home.html"
        },
        {
          "source": "/in/home.html",
          "destination": "/in/home.html"
        },
        {
          "source": "/en/vs-mindbody.html",
          "destination": "/en/vs-mindbody.html"
        },
        {
          "source": "/en/vs-vagaro.html",
          "destination": "/en/vs-vagaro.html"
        },
        {
          "source": "/ru/home.html",
          "destination": "/ru/home.html"
        },
        {
          "source": "/zh/home.html",
          "destination": "/zh/home.html"
        },
        {
          "source": "/es/home.html",
          "destination": "/es/home.html"
        },
        {
          "source": "/pt/home.html",
          "destination": "/pt/home.html"
        },
        {
          "source": "/fr/home.html",
          "destination": "/fr/home.html"
        },
        {
          "source": "/de/home.html",
          "destination": "/de/home.html"
        },
        {
          "source": "/au/home.html",
          "destination": "/au/home.html"
        },
        {
          "source": "/ca/home.html",
          "destination": "/ca/home.html"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "sw.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        }
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions"
  },
  "storage": {
    "rules": "storage.rules"
  }
}